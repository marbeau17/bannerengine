<?xml version="1.0" encoding="UTF-8"?>
<banner_templates category="dressing">

  <!-- ======================================================================
       dressing_01: 単品商品訴求型 (380x380)
       ボトル写真とキャッチコピーで商品を訴求
       ====================================================================== -->
  <banner_template>
    <meta>
      <category>dressing</category>
      <pattern_id>dressing_01</pattern_id>
      <pattern_name>単品商品訴求型</pattern_name>
      <width>380</width>
      <height>380</height>
      <unit>px</unit>
      <aspect_ratio>1:1</aspect_ratio>
      <layout_type>full_background</layout_type>
      <recommended_use>SNS広告・商品一覧サムネイル</recommended_use>
    </meta>
    <design>
      <background_type>color</background_type>
      <background_value>#FFF8F0</background_value>
      <primary_color>#3D2B1F</primary_color>
      <accent_color>#D4A853</accent_color>
      <font_style>NotoSansJP</font_style>
      <highlight_panel>bottom_light</highlight_panel>
    </design>
    <slots>
      <slot>
        <id>product_image</id>
        <type>image</type>
        <x>15</x>
        <y>3</y>
        <width>70</width>
        <height>55</height>
        <description>ドレッシングボトルの写真（白背景推奨）</description>
        <required>true</required>
        <format_hint>PNG with transparency, 532x418px recommended</format_hint>
      </slot>
      <slot>
        <id>product_name</id>
        <type>text</type>
        <x>5</x>
        <y>60</y>
        <width>90</width>
        <height>10</height>
        <description>商品名（例：和風ごまドレッシング）</description>
        <required>true</required>
        <max_chars>20</max_chars>
        <font_size_guideline>18px</font_size_guideline>
        <font_weight>bold</font_weight>
        <color>#3D2B1F</color>
      </slot>
      <slot>
        <id>catch_copy</id>
        <type>text</type>
        <x>5</x>
        <y>71</y>
        <width>90</width>
        <height>8</height>
        <description>キャッチコピー（例：毎日のサラダをもっと楽しく）</description>
        <required>true</required>
        <max_chars>25</max_chars>
        <font_size_guideline>14px</font_size_guideline>
        <color>#666666</color>
      </slot>
      <slot>
        <id>price</id>
        <type>text</type>
        <x>5</x>
        <y>80</y>
        <width>45</width>
        <height>8</height>
        <description>価格（例：¥398（税込））</description>
        <required>false</required>
        <max_chars>15</max_chars>
        <font_size_guideline>20px</font_size_guideline>
        <font_weight>bold</font_weight>
        <color>#D4A853</color>
      </slot>
      <slot>
        <id>cta_button</id>
        <type>button</type>
        <x>0</x>
        <y>89</y>
        <width>100</width>
        <height>11</height>
        <description>購入ページへのCTAボタン</description>
        <required>true</required>
        <default_label>詳しく見る</default_label>
        <bg_color>#D4A853</bg_color>
        <text_color>#FFFFFF</text_color>
      </slot>
    </slots>
    <rules>
      <rule>product_image は必須入力です。白背景・透過PNGのボトル写真を推奨します。</rule>
      <rule>product_name は最大20文字です。正式な商品名を記載してください。</rule>
      <rule>catch_copy は最大25文字です。商品の魅力を簡潔に表現してください。</rule>
      <rule>price を入力する場合は税込み表記を推奨します。</rule>
      <rule>画像は最低532x418px以上の解像度を推奨します。</rule>
    </rules>
  </banner_template>

  <!-- ======================================================================
       dressing_02: レシピ連動型 (1200x630)
       料理写真＋商品＋レシピ提案で訴求
       ====================================================================== -->
  <banner_template>
    <meta>
      <category>dressing</category>
      <pattern_id>dressing_02</pattern_id>
      <pattern_name>レシピ連動型</pattern_name>
      <width>1200</width>
      <height>630</height>
      <unit>px</unit>
      <aspect_ratio>40:21</aspect_ratio>
      <layout_type>grid</layout_type>
      <recommended_use>OGP画像・レシピサイト広告</recommended_use>
    </meta>
    <design>
      <background_type>color</background_type>
      <background_value>#FFFFFF</background_value>
      <primary_color>#333333</primary_color>
      <accent_color>#4CAF50</accent_color>
      <font_style>NotoSansJP</font_style>
      <highlight_panel>left_image_right_text</highlight_panel>
    </design>
    <slots>
      <slot>
        <id>recipe_photo</id>
        <type>image</type>
        <x>0</x>
        <y>0</y>
        <width>55</width>
        <height>100</height>
        <description>レシピ完成写真（サラダ・料理の写真）</description>
        <required>true</required>
        <format_hint>JPEG or PNG, 1320x1260px recommended</format_hint>
      </slot>
      <slot>
        <id>product_image</id>
        <type>image</type>
        <x>58</x>
        <y>5</y>
        <width>18</width>
        <height>30</height>
        <description>ドレッシングボトル写真</description>
        <required>true</required>
        <format_hint>PNG with transparency recommended</format_hint>
      </slot>
      <slot>
        <id>recipe_name</id>
        <type>text</type>
        <x>58</x>
        <y>38</y>
        <width>38</width>
        <height>10</height>
        <description>レシピ名（例：彩り野菜のグリーンサラダ）</description>
        <required>true</required>
        <max_chars>20</max_chars>
        <font_size_guideline>20px</font_size_guideline>
        <font_weight>bold</font_weight>
        <color>#333333</color>
      </slot>
      <slot>
        <id>catch_copy</id>
        <type>text</type>
        <x>58</x>
        <y>50</y>
        <width>38</width>
        <height>12</height>
        <description>キャッチコピー（例：かけるだけで本格レストランの味わい）</description>
        <required>true</required>
        <max_chars>30</max_chars>
        <font_size_guideline>15px</font_size_guideline>
        <color>#666666</color>
      </slot>
      <slot>
        <id>product_name</id>
        <type>text</type>
        <x>58</x>
        <y>64</y>
        <width>38</width>
        <height>8</height>
        <description>商品名（例：有機バジルドレッシング）</description>
        <required>true</required>
        <max_chars>20</max_chars>
        <font_size_guideline>16px</font_size_guideline>
        <font_weight>bold</font_weight>
        <color>#4CAF50</color>
      </slot>
      <slot>
        <id>sub_copy</id>
        <type>text</type>
        <x>58</x>
        <y>74</y>
        <width>38</width>
        <height>6</height>
        <description>補足テキスト（例：オーガニック素材100%使用）</description>
        <required>false</required>
        <max_chars>25</max_chars>
        <font_size_guideline>12px</font_size_guideline>
        <color>#999999</color>
      </slot>
      <slot>
        <id>cta_button</id>
        <type>button</type>
        <x>58</x>
        <y>83</y>
        <width>38</width>
        <height>12</height>
        <description>レシピページへのCTAボタン</description>
        <required>true</required>
        <default_label>レシピを見る</default_label>
        <bg_color>#4CAF50</bg_color>
        <text_color>#FFFFFF</text_color>
      </slot>
    </slots>
    <rules>
      <rule>recipe_photo は必須入力です。食欲をそそる料理写真を推奨します。</rule>
      <rule>product_image は必須入力です。透過PNG形式のボトル写真を推奨します。</rule>
      <rule>recipe_name は最大20文字です。</rule>
      <rule>catch_copy は最大30文字です。商品とレシピの両方の魅力を伝えてください。</rule>
      <rule>product_name は最大20文字です。正式な商品名を記載してください。</rule>
      <rule>cta_button のコントラスト比は WCAG AA 基準を確保してください。</rule>
    </rules>
  </banner_template>

  <!-- ======================================================================
       dressing_03: 新商品発売型 (996x998)
       NEW!バッジと大きなコピーで新商品を告知
       ====================================================================== -->
  <banner_template>
    <meta>
      <category>dressing</category>
      <pattern_id>dressing_03</pattern_id>
      <pattern_name>新商品発売型</pattern_name>
      <width>996</width>
      <height>998</height>
      <unit>px</unit>
      <aspect_ratio>498:499</aspect_ratio>
      <layout_type>copy_focused</layout_type>
      <recommended_use>Instagram投稿・新商品告知</recommended_use>
    </meta>
    <design>
      <background_type>color</background_type>
      <background_value>#F9F5EB</background_value>
      <primary_color>#2C1810</primary_color>
      <accent_color>#E8451E</accent_color>
      <font_style>NotoSansJP</font_style>
      <highlight_panel>new_badge_top</highlight_panel>
      <illustration_style>botanical</illustration_style>
    </design>
    <slots>
      <slot>
        <id>new_badge</id>
        <type>text</type>
        <x>35</x>
        <y>3</y>
        <width>30</width>
        <height>7</height>
        <description>NEWバッジ（例：NEW!）</description>
        <required>true</required>
        <max_chars>10</max_chars>
        <font_size_guideline>24px</font_size_guideline>
        <font_weight>bold</font_weight>
        <color>#FFFFFF</color>
      </slot>
      <slot>
        <id>catch_copy</id>
        <type>text</type>
        <x>5</x>
        <y>12</y>
        <width>90</width>
        <height>12</height>
        <description>メインキャッチコピー（例：素材の味を引き出す、新しい一本。）</description>
        <required>true</required>
        <max_chars>25</max_chars>
        <font_size_guideline>34px</font_size_guideline>
        <font_weight>bold</font_weight>
        <color>#2C1810</color>
      </slot>
      <slot>
        <id>product_image</id>
        <type>image</type>
        <x>20</x>
        <y>26</y>
        <width>60</width>
        <height>42</height>
        <description>新商品ボトルの大きな写真</description>
        <required>true</required>
        <format_hint>PNG with transparency, high resolution</format_hint>
      </slot>
      <slot>
        <id>product_name</id>
        <type>text</type>
        <x>5</x>
        <y>70</y>
        <width>90</width>
        <height>8</height>
        <description>新商品名（例：プレミアム柚子ドレッシング）</description>
        <required>true</required>
        <max_chars>25</max_chars>
        <font_size_guideline>22px</font_size_guideline>
        <font_weight>bold</font_weight>
        <color>#2C1810</color>
      </slot>
      <slot>
        <id>sub_copy</id>
        <type>text</type>
        <x>10</x>
        <y>79</y>
        <width>80</width>
        <height>6</height>
        <description>商品説明（例：国産柚子果汁をたっぷり使用した贅沢な味わい）</description>
        <required>false</required>
        <max_chars>35</max_chars>
        <font_size_guideline>14px</font_size_guideline>
        <color>#666666</color>
      </slot>
      <slot>
        <id>price</id>
        <type>text</type>
        <x>30</x>
        <y>86</y>
        <width>40</width>
        <height>5</height>
        <description>希望小売価格（例：¥498（税込））</description>
        <required>false</required>
        <max_chars>15</max_chars>
        <font_size_guideline>18px</font_size_guideline>
        <font_weight>bold</font_weight>
        <color>#E8451E</color>
      </slot>
      <slot>
        <id>cta_button</id>
        <type>button</type>
        <x>20</x>
        <y>92</y>
        <width>60</width>
        <height>7</height>
        <description>商品詳細ページへのCTAボタン</description>
        <required>true</required>
        <default_label>商品詳細はこちら</default_label>
        <bg_color>#E8451E</bg_color>
        <text_color>#FFFFFF</text_color>
      </slot>
    </slots>
    <rules>
      <rule>new_badge は必須入力です。「NEW」「新発売」などの短いテキストを記載してください。</rule>
      <rule>catch_copy は最大25文字です。新商品の魅力を端的に伝えてください。</rule>
      <rule>product_image は必須入力です。高解像度の透過PNG画像を推奨します。</rule>
      <rule>product_name は最大25文字です。正式な商品名を記載してください。</rule>
      <rule>price を入力する場合は税込み表記を推奨します。</rule>
    </rules>
  </banner_template>

  <!-- ======================================================================
       dressing_04: キャンペーン型 (600x254)
       割引情報と複数商品を配置
       ====================================================================== -->
  <banner_template>
    <meta>
      <category>dressing</category>
      <pattern_id>dressing_04</pattern_id>
      <pattern_name>キャンペーン型</pattern_name>
      <width>600</width>
      <height>254</height>
      <unit>px</unit>
      <aspect_ratio>300:127</aspect_ratio>
      <layout_type>grid</layout_type>
      <recommended_use>ウェブバナー・メルマガ挿入広告</recommended_use>
    </meta>
    <design>
      <background_type>color</background_type>
      <background_value>#FFF3E0</background_value>
      <primary_color>#333333</primary_color>
      <accent_color>#FF6F00</accent_color>
      <font_style>NotoSansJP</font_style>
      <highlight_panel>discount_banner</highlight_panel>
    </design>
    <slots>
      <slot>
        <id>campaign_title</id>
        <type>text</type>
        <x>3</x>
        <y>3</y>
        <width>60</width>
        <height>16</height>
        <description>キャンペーンタイトル（例：春のまとめ買いフェア）</description>
        <required>true</required>
        <max_chars>18</max_chars>
        <font_size_guideline>20px</font_size_guideline>
        <font_weight>bold</font_weight>
        <color>#333333</color>
      </slot>
      <slot>
        <id>discount_badge</id>
        <type>text</type>
        <x>65</x>
        <y>3</y>
        <width>32</width>
        <height>16</height>
        <description>割引情報（例：最大30%OFF）</description>
        <required>true</required>
        <max_chars>12</max_chars>
        <font_size_guideline>22px</font_size_guideline>
        <font_weight>bold</font_weight>
        <color>#FF6F00</color>
      </slot>
      <slot>
        <id>product_image_1</id>
        <type>image</type>
        <x>3</x>
        <y>22</y>
        <width>22</width>
        <height>48</height>
        <description>商品写真1</description>
        <required>true</required>
        <format_hint>PNG with transparency</format_hint>
      </slot>
      <slot>
        <id>product_image_2</id>
        <type>image</type>
        <x>28</x>
        <y>22</y>
        <width>22</width>
        <height>48</height>
        <description>商品写真2</description>
        <required>true</required>
        <format_hint>PNG with transparency</format_hint>
      </slot>
      <slot>
        <id>product_image_3</id>
        <type>image</type>
        <x>53</x>
        <y>22</y>
        <width>22</width>
        <height>48</height>
        <description>商品写真3</description>
        <required>false</required>
        <format_hint>PNG with transparency</format_hint>
      </slot>
      <slot>
        <id>campaign_period</id>
        <type>text</type>
        <x>3</x>
        <y>72</y>
        <width>72</width>
        <height>10</height>
        <description>キャンペーン期間（例：2026/3/1〜3/31）</description>
        <required>false</required>
        <max_chars>25</max_chars>
        <font_size_guideline>11px</font_size_guideline>
        <color>#999999</color>
      </slot>
      <slot>
        <id>cta_button</id>
        <type>button</type>
        <x>60</x>
        <y>73</y>
        <width>37</width>
        <height>25</height>
        <description>キャンペーンページへのCTAボタン</description>
        <required>true</required>
        <default_label>お得に買う</default_label>
        <bg_color>#FF6F00</bg_color>
        <text_color>#FFFFFF</text_color>
      </slot>
    </slots>
    <rules>
      <rule>campaign_title は必須入力です。18文字以内で簡潔に記載してください。</rule>
      <rule>discount_badge は必須入力です。割引率を明確に表示してください。</rule>
      <rule>product_image_1 および product_image_2 は必須入力です。</rule>
      <rule>商品画像は統一されたサイズ・背景で撮影してください。</rule>
      <rule>campaign_period を入力する場合は開始日と終了日を含めてください。</rule>
    </rules>
  </banner_template>

</banner_templates>
