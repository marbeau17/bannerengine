<?xml version="1.0" encoding="UTF-8"?>
<banner_templates category="stationery">

  <!-- ======================================================================
       stationery_01: 新学期セール型 (1200x630)
       商品群写真＋割引率で新学期セールを訴求
       ====================================================================== -->
  <banner_template>
    <meta>
      <category>stationery</category>
      <pattern_id>stationery_01</pattern_id>
      <pattern_name>新学期セール型</pattern_name>
      <width>1200</width>
      <height>630</height>
      <unit>px</unit>
      <aspect_ratio>40:21</aspect_ratio>
      <layout_type>full_background</layout_type>
      <recommended_use>OGP画像・ウェブバナー広告</recommended_use>
    </meta>
    <design>
      <background_type>color</background_type>
      <background_value>#E3F2FD</background_value>
      <primary_color>#1565C0</primary_color>
      <accent_color>#FF6F00</accent_color>
      <font_style>NotoSansJP</font_style>
      <highlight_panel>diagonal_stripe</highlight_panel>
      <illustration_style>geometric</illustration_style>
    </design>
    <slots>
      <slot>
        <id>sale_badge</id>
        <type>text</type>
        <x>3</x>
        <y>3</y>
        <width>40</width>
        <height>12</height>
        <description>セールバッジ（例：新学期応援SALE）</description>
        <required>true</required>
        <max_chars>15</max_chars>
        <font_size_guideline>28px</font_size_guideline>
        <font_weight>bold</font_weight>
        <color>#1565C0</color>
      </slot>
      <slot>
        <id>discount_rate</id>
        <type>text</type>
        <x>50</x>
        <y>3</y>
        <width>47</width>
        <height>12</height>
        <description>割引率表示（例：最大50%OFF）</description>
        <required>true</required>
        <max_chars>15</max_chars>
        <font_size_guideline>32px</font_size_guideline>
        <font_weight>bold</font_weight>
        <color>#FF6F00</color>
      </slot>
      <slot>
        <id>products_image</id>
        <type>image</type>
        <x>5</x>
        <y>18</y>
        <width>55</width>
        <height>55</height>
        <description>文房具商品群の写真（ペン・ノート・定規など）</description>
        <required>true</required>
        <format_hint>JPEG or PNG, 1320x693px recommended</format_hint>
      </slot>
      <slot>
        <id>catch_copy</id>
        <type>text</type>
        <x>62</x>
        <y>22</y>
        <width>35</width>
        <height>15</height>
        <description>キャッチコピー（例：新しい学びに、新しい文房具を。）</description>
        <required>true</required>
        <max_chars>25</max_chars>
        <font_size_guideline>22px</font_size_guideline>
        <font_weight>bold</font_weight>
        <color>#1565C0</color>
      </slot>
      <slot>
        <id>sub_copy</id>
        <type>text</type>
        <x>62</x>
        <y>40</y>
        <width>35</width>
        <height>12</height>
        <description>補足テキスト（例：人気ブランド勢揃い！ノート・ペン・バッグまで）</description>
        <required>false</required>
        <max_chars>35</max_chars>
        <font_size_guideline>14px</font_size_guideline>
        <color>#666666</color>
      </slot>
      <slot>
        <id>sale_period</id>
        <type>text</type>
        <x>62</x>
        <y>55</y>
        <width>35</width>
        <height>8</height>
        <description>セール期間（例：3/1(土)〜4/10(木)）</description>
        <required>false</required>
        <max_chars>25</max_chars>
        <font_size_guideline>13px</font_size_guideline>
        <color>#999999</color>
      </slot>
      <slot>
        <id>cta_button</id>
        <type>button</type>
        <x>5</x>
        <y>80</y>
        <width>90</width>
        <height>15</height>
        <description>セールページへのCTAボタン</description>
        <required>true</required>
        <default_label>セール会場へ</default_label>
        <bg_color>#FF6F00</bg_color>
        <text_color>#FFFFFF</text_color>
      </slot>
    </slots>
    <rules>
      <rule>sale_badge は必須入力です。セール名を簡潔に15文字以内で記載してください。</rule>
      <rule>discount_rate は必須入力です。割引率を明確に表示してください。</rule>
      <rule>products_image は必須入力です。商品が複数映った写真を推奨します。</rule>
      <rule>catch_copy は最大25文字です。ターゲットユーザーに響くコピーを記載してください。</rule>
      <rule>cta_button のコントラスト比は WCAG AA 基準（4.5:1以上）を確保してください。</rule>
    </rules>
  </banner_template>

  <!-- ======================================================================
       stationery_02: 単品商品訴求型 (380x380)
       商品クローズアップ＋機能説明
       ====================================================================== -->
  <banner_template>
    <meta>
      <category>stationery</category>
      <pattern_id>stationery_02</pattern_id>
      <pattern_name>単品商品訴求型</pattern_name>
      <width>380</width>
      <height>380</height>
      <unit>px</unit>
      <aspect_ratio>1:1</aspect_ratio>
      <layout_type>full_background</layout_type>
      <recommended_use>SNS広告・商品一覧サムネイル</recommended_use>
    </meta>
    <design>
      <background_type>color</background_type>
      <background_value>#F5F5F5</background_value>
      <primary_color>#212121</primary_color>
      <accent_color>#1565C0</accent_color>
      <font_style>NotoSansJP</font_style>
      <highlight_panel>clean_minimal</highlight_panel>
    </design>
    <slots>
      <slot>
        <id>product_image</id>
        <type>image</type>
        <x>10</x>
        <y>3</y>
        <width>80</width>
        <height>52</height>
        <description>文房具商品クローズアップ写真</description>
        <required>true</required>
        <format_hint>PNG with transparency, 608x395px recommended</format_hint>
      </slot>
      <slot>
        <id>product_name</id>
        <type>text</type>
        <x>5</x>
        <y>57</y>
        <width>90</width>
        <height>10</height>
        <description>商品名（例：ジェットストリーム 4&amp;1 多機能ペン）</description>
        <required>true</required>
        <max_chars>25</max_chars>
        <font_size_guideline>16px</font_size_guideline>
        <font_weight>bold</font_weight>
        <color>#212121</color>
      </slot>
      <slot>
        <id>feature_text</id>
        <type>text</type>
        <x>5</x>
        <y>68</y>
        <width>90</width>
        <height>8</height>
        <description>機能説明（例：なめらかな書き心地、4色+シャープ）</description>
        <required>false</required>
        <max_chars>30</max_chars>
        <font_size_guideline>12px</font_size_guideline>
        <color>#666666</color>
      </slot>
      <slot>
        <id>price</id>
        <type>text</type>
        <x>5</x>
        <y>78</y>
        <width>45</width>
        <height>10</height>
        <description>価格（例：¥1,100（税込））</description>
        <required>true</required>
        <max_chars>15</max_chars>
        <font_size_guideline>22px</font_size_guideline>
        <font_weight>bold</font_weight>
        <color>#1565C0</color>
      </slot>
      <slot>
        <id>cta_button</id>
        <type>button</type>
        <x>0</x>
        <y>89</y>
        <width>100</width>
        <height>11</height>
        <description>商品詳細ページへのCTAボタン</description>
        <required>true</required>
        <default_label>商品を見る</default_label>
        <bg_color>#1565C0</bg_color>
        <text_color>#FFFFFF</text_color>
      </slot>
    </slots>
    <rules>
      <rule>product_image は必須入力です。商品のディテールが見える写真を推奨します。</rule>
      <rule>product_name は最大25文字です。正式な商品名を記載してください。</rule>
      <rule>price は必須入力です。税込み表記を推奨します。</rule>
      <rule>feature_text は最大30文字です。商品の特長を簡潔に表現してください。</rule>
      <rule>画像は最低608x395px以上の解像度を推奨します。</rule>
    </rules>
  </banner_template>

  <!-- ======================================================================
       stationery_03: ギフト提案型 (996x998)
       ギフトボックス風レイアウトでギフト需要を訴求
       ====================================================================== -->
  <banner_template>
    <meta>
      <category>stationery</category>
      <pattern_id>stationery_03</pattern_id>
      <pattern_name>ギフト提案型</pattern_name>
      <width>996</width>
      <height>998</height>
      <unit>px</unit>
      <aspect_ratio>498:499</aspect_ratio>
      <layout_type>copy_focused</layout_type>
      <recommended_use>Instagram投稿・ギフト特集ページ</recommended_use>
    </meta>
    <design>
      <background_type>color</background_type>
      <background_value>#FFF8E1</background_value>
      <primary_color>#4E342E</primary_color>
      <accent_color>#D4A853</accent_color>
      <font_style>NotoSansJP</font_style>
      <highlight_panel>gift_ribbon</highlight_panel>
      <illustration_style>ribbon_decoration</illustration_style>
    </design>
    <slots>
      <slot>
        <id>gift_badge</id>
        <type>text</type>
        <x>25</x>
        <y>3</y>
        <width>50</width>
        <height>8</height>
        <description>ギフトバッジ（例：GIFT SELECTION）</description>
        <required>true</required>
        <max_chars>20</max_chars>
        <font_size_guideline>22px</font_size_guideline>
        <font_weight>bold</font_weight>
        <color>#D4A853</color>
      </slot>
      <slot>
        <id>catch_copy</id>
        <type>text</type>
        <x>5</x>
        <y>12</y>
        <width>90</width>
        <height>10</height>
        <description>キャッチコピー（例：大切な人へ、書く喜びを贈ろう。）</description>
        <required>true</required>
        <max_chars>25</max_chars>
        <font_size_guideline>28px</font_size_guideline>
        <font_weight>bold</font_weight>
        <color>#4E342E</color>
      </slot>
      <slot>
        <id>gift_image</id>
        <type>image</type>
        <x>10</x>
        <y>24</y>
        <width>80</width>
        <height>40</height>
        <description>ギフトセット写真（ラッピングされた文房具セット）</description>
        <required>true</required>
        <format_hint>JPEG or PNG, 1594x798px recommended</format_hint>
      </slot>
      <slot>
        <id>price_range</id>
        <type>text</type>
        <x>5</x>
        <y>66</y>
        <width>90</width>
        <height>7</height>
        <description>価格帯（例：¥2,000〜¥10,000）</description>
        <required>true</required>
        <max_chars>20</max_chars>
        <font_size_guideline>20px</font_size_guideline>
        <font_weight>bold</font_weight>
        <color>#D4A853</color>
      </slot>
      <slot>
        <id>target_text</id>
        <type>text</type>
        <x>5</x>
        <y>74</y>
        <width>90</width>
        <height>6</height>
        <description>対象説明（例：入学祝い・就職祝い・誕生日プレゼントに）</description>
        <required>false</required>
        <max_chars>30</max_chars>
        <font_size_guideline>14px</font_size_guideline>
        <color>#666666</color>
      </slot>
      <slot>
        <id>sub_copy</id>
        <type>text</type>
        <x>10</x>
        <y>81</y>
        <width>80</width>
        <height>5</height>
        <description>補足テキスト（例：無料ラッピング・名入れサービス対応）</description>
        <required>false</required>
        <max_chars>30</max_chars>
        <font_size_guideline>13px</font_size_guideline>
        <color>#999999</color>
      </slot>
      <slot>
        <id>cta_button</id>
        <type>button</type>
        <x>20</x>
        <y>88</y>
        <width>60</width>
        <height>10</height>
        <description>ギフト特集ページへのCTAボタン</description>
        <required>true</required>
        <default_label>ギフトを選ぶ</default_label>
        <bg_color>#D4A853</bg_color>
        <text_color>#FFFFFF</text_color>
      </slot>
    </slots>
    <rules>
      <rule>gift_badge は必須入力です。ギフトコンセプトを明確にしてください。</rule>
      <rule>catch_copy は最大25文字です。贈り物の気持ちが伝わるコピーを記載してください。</rule>
      <rule>gift_image は必須入力です。ギフトラッピングされた写真を推奨します。</rule>
      <rule>price_range は必須入力です。購入検討に必要な価格帯を記載してください。</rule>
      <rule>target_text に対象シーンを記載すると訴求力が高まります。</rule>
    </rules>
  </banner_template>

  <!-- ======================================================================
       stationery_04: 新商品一覧型 (600x254)
       複数商品をグリッド形式で一覧表示
       ====================================================================== -->
  <banner_template>
    <meta>
      <category>stationery</category>
      <pattern_id>stationery_04</pattern_id>
      <pattern_name>新商品一覧型</pattern_name>
      <width>600</width>
      <height>254</height>
      <unit>px</unit>
      <aspect_ratio>300:127</aspect_ratio>
      <layout_type>grid</layout_type>
      <recommended_use>ウェブバナー・メルマガ挿入画像</recommended_use>
    </meta>
    <design>
      <background_type>color</background_type>
      <background_value>#FFFFFF</background_value>
      <primary_color>#212121</primary_color>
      <accent_color>#1565C0</accent_color>
      <font_style>NotoSansJP</font_style>
      <highlight_panel>product_grid</highlight_panel>
    </design>
    <slots>
      <slot>
        <id>header_copy</id>
        <type>text</type>
        <x>3</x>
        <y>3</y>
        <width>94</width>
        <height>14</height>
        <description>ヘッダーコピー（例：NEW ARRIVALS - 新商品入荷）</description>
        <required>true</required>
        <max_chars>25</max_chars>
        <font_size_guideline>18px</font_size_guideline>
        <font_weight>bold</font_weight>
        <color>#212121</color>
      </slot>
      <slot>
        <id>product_image_1</id>
        <type>image</type>
        <x>3</x>
        <y>20</y>
        <width>22</width>
        <height>48</height>
        <description>新商品写真1</description>
        <required>true</required>
        <format_hint>PNG with transparency</format_hint>
      </slot>
      <slot>
        <id>product_image_2</id>
        <type>image</type>
        <x>28</x>
        <y>20</y>
        <width>22</width>
        <height>48</height>
        <description>新商品写真2</description>
        <required>true</required>
        <format_hint>PNG with transparency</format_hint>
      </slot>
      <slot>
        <id>product_image_3</id>
        <type>image</type>
        <x>53</x>
        <y>20</y>
        <width>22</width>
        <height>48</height>
        <description>新商品写真3</description>
        <required>false</required>
        <format_hint>PNG with transparency</format_hint>
      </slot>
      <slot>
        <id>product_image_4</id>
        <type>image</type>
        <x>78</x>
        <y>20</y>
        <width>19</width>
        <height>48</height>
        <description>新商品写真4</description>
        <required>false</required>
        <format_hint>PNG with transparency</format_hint>
      </slot>
      <slot>
        <id>sub_copy</id>
        <type>text</type>
        <x>3</x>
        <y>71</y>
        <width>55</width>
        <height>10</height>
        <description>補足テキスト（例：全品送料無料キャンペーン中）</description>
        <required>false</required>
        <max_chars>25</max_chars>
        <font_size_guideline>12px</font_size_guideline>
        <color>#666666</color>
      </slot>
      <slot>
        <id>cta_button</id>
        <type>button</type>
        <x>60</x>
        <y>72</y>
        <width>37</width>
        <height>25</height>
        <description>商品一覧ページへのCTAボタン</description>
        <required>true</required>
        <default_label>すべて見る</default_label>
        <bg_color>#1565C0</bg_color>
        <text_color>#FFFFFF</text_color>
      </slot>
    </slots>
    <rules>
      <rule>header_copy は必須入力です。25文字以内で簡潔に記載してください。</rule>
      <rule>product_image_1 および product_image_2 は必須入力です。</rule>
      <rule>商品写真は統一された白背景で撮影してください。</rule>
      <rule>グリッド内の商品画像サイズは統一推奨です。</rule>
      <rule>cta_button のコントラスト比は WCAG AA 基準を確保してください。</rule>
    </rules>
  </banner_template>

</banner_templates>
